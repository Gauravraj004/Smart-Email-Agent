# ============================================================
# ENVIRONMENT VARIABLES - Fill in your API keys below
# See README.md Step 3 for instructions on getting these keys
# ============================================================

# Gemini API Keys - System rotates between them if one hits rate limit
# Get your keys from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY_1=YOUR_GEMINI_API_KEY_1
GOOGLE_API_KEY_2=YOUR_GEMINI_API_KEY_2
GOOGLE_API_KEY_3=YOUR_GEMINI_API_KEY_3
GOOGLE_API_KEY_4=YOUR_GEMINI_API_KEY_4

# Primary key (same as KEY_1, kept for backward compatibility)
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY_1

# HuggingFace API Token (optional - for advanced AI features)
# Get your token from: https://huggingface.co/settings/tokens
HUGGINGFACEHUB_API_TOKEN=YOUR_HUGGINGFACE_TOKEN
